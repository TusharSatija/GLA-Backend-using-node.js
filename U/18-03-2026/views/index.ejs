<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>List all product</title>
</head>
<body>
        <article>
           <%  Products.map((data)=>{ %>
                 <img src="<%= data.url %>" alt="" srcset=""  height="200px" width="200px">
                <h1>Name :  <%= data.Pname %></h1>
                <h4>Price : <%= data.Pprice %></h4>
                <aside>
                    <button><a href="">Show</a></button>
                    <button><a href="">Edit</a></button>
                    <button><a href="">Delete</a></button>
                </aside>

            <% }) %>
        </article>

</body>
</html>