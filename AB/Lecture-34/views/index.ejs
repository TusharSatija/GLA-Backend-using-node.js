<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Products</title>
</head>
<body>
    <h1>List all Products</h1>
    <article>
        <% p.map((data)=>{ %>
            <section>
                <img src="<%= data.img %>" alt="" height="200px" width="200px">
                <h6>Name : <%= data.name %></h6>
                <h6>price : <%= data.price %></h6>
                <span> Rating : <%= data.rating %></span>
                <br>
                <button><a href="/product/<%=data._id%>">show</a></button>
                <button><a href="/product/<%=data._id%>/edit">edit</a></button>
                <button><a href="/product/<%=data._id %>">delete</a></button>
            </section>
        <% }) %>
    </article>
</body>
</html>